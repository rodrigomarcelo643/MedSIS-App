{
  "name": "MedSIS",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "------ DEV ------": "echo 'Development scripts'",
    "start": "expo start",
    "start:clear": "node scripts/dev/start.js --clear",
    "start:tunnel": "node scripts/dev/start.js --tunnel",
    "android": "node scripts/dev/start.js --android",
    "ios": "node scripts/dev/start.js --ios",
    "web": "node scripts/dev/start.js --web",

    "------ PREBUILD ------": "echo 'Prebuild scripts'",
    "prebuild": "node scripts/prebuild/prebuild.js all",
    "prebuild:android": "node scripts/prebuild/prebuild.js android",
    "prebuild:ios": "node scripts/prebuild/prebuild.js ios",
    "prebuild:clean": "node scripts/prebuild/prebuild.js all",

    "------ LOCAL BUILD ------": "echo 'Local build scripts'",
    "build:android:apk": "node scripts/build/local-build.js apk",
    "build:android:aab": "node scripts/build/local-build.js aab",
    "build:android": "node scripts/build/local-build.js android",
    "build:ios": "node scripts/build/local-build.js ios",

    "------ EAS CLOUD ------": "echo 'EAS Cloud build scripts'",
    "eas:build:android:dev": "node scripts/eas/cloud-build.js android development",
    "eas:build:android:staging": "node scripts/eas/cloud-build.js android preview",
    "eas:build:android:prod": "node scripts/eas/cloud-build.js android production",
    "eas:build:ios:dev": "node scripts/eas/cloud-build.js ios development",
    "eas:build:ios:staging": "node scripts/eas/cloud-build.js ios preview",
    "eas:build:ios:prod": "node scripts/eas/cloud-build.js ios production",
    "eas:build:all:prod": "node scripts/eas/cloud-build.js all production",
    "eas:submit:android": "node scripts/eas/submit.js android",
    "eas:submit:ios": "node scripts/eas/submit.js ios",
    "eas:update": "node scripts/eas/ota-update.js",

    "------ QUALITY ------": "echo 'Quality check scripts'",
    "lint": "expo lint",
    "lint:fix": "node scripts/quality/check.js --fix",
    "typecheck": "tsc --noEmit",
    "quality": "node scripts/quality/check.js",
    "audit:assets": "node scripts/quality/audit-assets.js",

    "------ UTILITIES ------": "echo 'Utility scripts'",
    "reset-project": "node scripts/reset-project.js",
    "doctor": "node scripts/utils/doctor.js",
    "deps:check": "node scripts/utils/check-deps.js",
    "deps:upgrade": "node scripts/utils/check-deps.js --upgrade",
    "cache:clear": "node scripts/utils/clear-cache.js",
    "cache:deep": "node scripts/utils/clear-cache.js --deep"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.3.10",
    "@react-navigation/elements": "^2.3.8",
    "@react-navigation/native": "^7.1.6",
    "@rn-primitives/avatar": "^1.2.0",
    "@rn-primitives/label": "^1.2.0",
    "axios": "^1.11.0",
    "babel-preset-expo": "~13.0.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "expo": "~53.0.24",
    "expo-av": "~15.1.7",
    "expo-blur": "~14.1.5",
    "expo-camera": "~16.1.11",
    "expo-checkbox": "~4.1.4",
    "expo-constants": "~17.1.8",
    "expo-device": "~7.1.4",
    "expo-document-picker": "^13.1.6",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.1",
    "expo-haptics": "~14.1.4",
    "expo-image": "~2.4.1",
    "expo-image-picker": "~16.1.4",
    "expo-intent-launcher": "~12.1.5",
    "expo-linking": "~7.1.7",
    "expo-notifications": "~0.31.4",
    "expo-router": "~5.1.7",
    "expo-sharing": "~13.1.5",
    "expo-speech": "~13.1.7",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "expo-symbols": "~0.4.5",
    "expo-system-ui": "~5.0.11",
    "expo-updates": "~0.28.17",
    "expo-web-browser": "~14.2.0",
    "lucide-react": "^0.523.0",
    "lucide-react-native": "^0.523.0",
    "moti": "^0.30.0",
    "nativewind": "^4.1.23",
    "postcss": "^8.5.6",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-chart-kit": "^6.12.0",
    "react-native-css-interop": "^0.1.22",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-bottom-sheet": "^1.1.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-heroicons": "^4.0.0",
    "react-native-pdf": "^6.7.7",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-skeleton-placeholder": "^5.2.4",
    "react-native-svg": "15.11.2",
    "react-native-toast-message": "^2.3.1",
    "react-native-tts": "^4.1.1",
    "react-native-webview": "13.13.5",
    "react-native-wind": "^1.2.0",
    "tailwindcss": "^3.4.17",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-typescript": "^7.27.1",
    "@expo/metro-config": "~0.20.0",
    "@types/react": "~19.0.10",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~9.2.0",
    "react-native-svg-transformer": "^1.5.1",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "metroConfigCheck": false,
      "reactNativeDirectoryCheck": {
        "exclude": [
          "dotenv",
          "lucide-react",
          "postcss",
          "prettier-plugin-tailwindcss",
          "react-native-css-interop",
          "react-native-gesture-bottom-sheet",
          "react-native-wind",
          "tslib",
          "react-native-chart-kit",
          "react-native-heroicons",
          "react-native-tts",
          "react-native-skeleton-placeholder",
          "crypto-js"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
